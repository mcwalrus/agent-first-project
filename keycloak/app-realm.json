{
  "realm": "sms",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "smtpServer": {
    "host": "smtp.resend.com",
    "port": "587",
    "from": "${KC_SMTP_FROM}",
    "fromDisplayName": "Test org",
    "ssl": "false",
    "starttls": "true",
    "auth": "true",
    "user": "resend",
    "password": "${KC_SMTP_PASSWORD}"
  },
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standard user for local testing"
      }
    ],
    "client": {}
  },
  "clients": [
    {
      "clientId": "sms-web",
      "name": "sms-web",
      "description": "SMS Web Application (Authorization Code Flow)",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "sms-web-dev-secret",
      "redirectUris": ["http://localhost:3000/*", "http://localhost:3000"],
      "webOrigins": ["http://localhost:3000"],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "publicClient": false,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "attributes": {
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false",
        "post.logout.redirect.uris": "http://localhost:3000/login"
      },
      "protocolMappers": [
        {
          "name": "role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "false",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "role",
            "jsonType.label": "String"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "false",
            "claim.name": "groups",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "clientId": "sms-admin",
      "name": "sms-admin",
      "description": "SMS Admin Service Account \u2014 used by the app to call Keycloak Admin REST API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "sms-admin-dev-secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {}
    }
  ],
  "groups": [
    {
      "name": "test-org",
      "path": "/test-org",
      "attributes": {},
      "realmRoles": [],
      "clientRoles": {},
      "subGroups": []
    }
  ],
  "users": [
    {
      "username": "test-user",
      "email": "user@test-org.local",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Test1234!",
          "temporary": false
        }
      ],
      "realmRoles": ["USER"],
      "groups": ["/test-org"]
    },
    {
      "username": "service-account-sms-admin",
      "enabled": true,
      "serviceAccountClientId": "sms-admin",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "manage-realm"]
      }
    }
  ]
}
