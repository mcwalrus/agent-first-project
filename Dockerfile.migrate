FROM node:22-alpine

RUN apk add --no-cache openssl

WORKDIR /app

# Install dependencies — this layer is cached until package.json / yarn.lock change
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile --ignore-scripts

# Copy only the prisma directory — Docker rebuilds from here only when migrations change
COPY prisma ./prisma
RUN ./node_modules/.bin/prisma generate

CMD ["./node_modules/.bin/prisma", "migrate", "deploy"]
