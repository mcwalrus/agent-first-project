# Database (matches docker-compose.yml; run with: just db-up)
DATABASE_URL="postgresql://user:password@localhost:5432/app_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Keycloak OIDC (NextAuth Keycloak provider — realm imported on `docker compose up`; see keycloak/ and README)
KEYCLOAK_CLIENT_ID="sms-web"
KEYCLOAK_CLIENT_SECRET="sms-web-dev-secret"
KEYCLOAK_ISSUER="http://localhost:8080/realms/sms"

# Keycloak Docker Compose (see docker-compose.yml)
KEYCLOAK_ADMIN="admin"
KEYCLOAK_ADMIN_PASSWORD="admin"
KC_DB_USERNAME="keycloak"
KC_DB_PASSWORD="keycloak"

# Optional: Keycloak SMTP (realm JSON references these env vars when present)
# KC_SMTP_PASSWORD=
# KC_SMTP_FROM=noreply@example.com

# Playwright (defaults to http://localhost:3000)
PLAYWRIGHT_BASE_URL="http://localhost:3000"
